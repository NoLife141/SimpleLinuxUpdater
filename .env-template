# Copy this file to .env and update values before running Docker.

# Required: bearer token used to protect /metrics (Prometheus scrape auth)
DEBIAN_UPDATER_METRICS_BEARER_TOKEN=

# Optional: session cookie hardening (recommended true behind HTTPS reverse proxy)
# DEBIAN_UPDATER_SESSION_COOKIE_SECURE=false

# Optional: idle timeout for web sessions in hours (0/unset keeps default behavior)
# DEBIAN_UPDATER_SESSION_IDLE_TIMEOUT_HOURS=0

# Optional: custom DB path inside the container
# DEBIAN_UPDATER_DB_PATH=/data/servers.db

# Optional: override known_hosts paths inside the container
# Default is /data/known_hosts (persisted with the volume)
# DEBIAN_UPDATER_KNOWN_HOSTS=/data/known_hosts:/etc/ssh/ssh_known_hosts

# Optional: retry policy for transient SSH/network/APT failures
# DEBIAN_UPDATER_RETRY_MAX_ATTEMPTS=3
# DEBIAN_UPDATER_RETRY_BASE_DELAY_MS=1000
# DEBIAN_UPDATER_RETRY_MAX_DELAY_MS=8000
# DEBIAN_UPDATER_RETRY_JITTER_PCT=20
